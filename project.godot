; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Break the Loop"
config/description="懸疑文字冒險 × 解謎推理 × 情報繼承 — 完美公主的無知，造就了亡國的迴圈。"
run/main_scene="res://scenes/main_menu/main_menu.tscn"
config/features=PackedStringArray("4.6")
config/icon="res://icon.svg"

[autoload]

GameManager="*res://autoload/game_manager.gd"
IntelSystem="*res://autoload/intel_system.gd"
LoopManager="*res://autoload/loop_manager.gd"
AudioManager="*res://autoload/audio_manager.gd"
FlowLogger="*res://autoload/flow_logger.gd"
SceneTransition="*res://autoload/scene_transition.tscn"
Dialogic="*uid://ds2q0uclmolvu"
DialogicCustomizer="*res://autoload/dialogic_customizer.gd"

[dialogic]

directories/dch_directory={
"chancellor": "res://dialogic/characters/chancellor.dch",
"loyal_retainer": "res://dialogic/characters/loyal_retainer.dch",
"maid": "res://dialogic/characters/maid.dch",
"princess": "res://dialogic/characters/princess.dch",
"suspect_a": "res://dialogic/characters/suspect_a.dch",
"suspect_b": "res://dialogic/characters/suspect_b.dch",
"suspect_c": "res://dialogic/characters/suspect_c.dch"
}
directories/dtl_directory={
"awakening": "res://dialogic/timelines/loop_1/awakening.dtl",
"awakening_cutscene": "res://dialogic/timelines/loop_1/awakening_cutscene.dtl",
"awakening_with_intel": "res://dialogic/timelines/loop_2/awakening_with_intel.dtl",
"bad_end_a": "res://dialogic/timelines/loop_1/bad_end_a.dtl",
"betrayal": "res://dialogic/timelines/loop_1/betrayal.dtl",
"branch_a_death": "res://dialogic/timelines/loop_1/branch_a_death.dtl",
"branch_a_revisit": "res://dialogic/timelines/loop_2/branch_a_revisit.dtl",
"branch_b_death": "res://dialogic/timelines/loop_2/branch_b_death.dtl",
"branch_b_unlock": "res://dialogic/timelines/loop_2/branch_b_unlock.dtl",
"chancellor_visit": "res://dialogic/timelines/loop_1/chancellor_visit.dtl",
"evidence": "res://dialogic/timelines/loop_1/evidence.dtl",
"final_confrontation": "res://dialogic/timelines/final_loop/final_confrontation.dtl",
"heist": "res://dialogic/timelines/loop_1/heist.dtl",
"investigation_a": "res://dialogic/timelines/loop_1/investigation_a.dtl",
"lower_district": "res://dialogic/timelines/loop_1/lower_district.dtl",
"maid_morning": "res://dialogic/timelines/loop_1/maid_morning.dtl",
"prologue_assassination": "res://dialogic/timelines/prologue/prologue_assassination.dtl",
"prologue_death": "res://dialogic/timelines/prologue/prologue_death.dtl",
"prologue_main": "res://dialogic/timelines/prologue/prologue_main.dtl",
"true_ending": "res://dialogic/timelines/final_loop/true_ending.dtl"
}
layout/style_directory={
"": "res://dialogic/styles/custom_vn_style.tres",
"Custom VN Style": "res://dialogic/styles/custom_vn_style.tres",
"Visual Novel Style": "res://addons/dialogic/Modules/DefaultLayoutParts/Style_VN_Default/default_vn_style.tres"
}
layout/default_style="res://dialogic/styles/custom_vn_style.tres"
layout/style_list=["res://dialogic/styles/custom_vn_style.tres", "res://addons/dialogic/Modules/DefaultLayoutParts/Style_VN_Default/default_vn_style.tres"]

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="canvas_items"

[dotnet]

project/assembly_name="Break the Loop"

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogic/plugin.cfg")

