# 序章：王城陷落 — 開場敘事

[style name="flashback_style"]
# [PLACEHOLDER] [background arg="res://art/backgrounds/city_fall.png" fade="1.5"]
# [PLACEHOLDER] [music path="res://audio/bgm/prologue_epic.ogg" fade="2.0"]
