[sub_resource type="Resource" id="intel_city_fall"]
script = ExtResource("2")
id = "intel_city_fall"
title = "城破的結果"
description = "王城在大火中陷落，一切都在一夜之間崩塌。這是公主親眼見證的末日。"
category = &"general"
source_loop = 0
unlocks_branches = []

[sub_resource type="Resource" id="intel_assassination"]
script = ExtResource("2")
id = "intel_assassination"
title = "騎士長的刀"
description = "騎士長賽拉斯含淚刺殺了公主——他說這是國王最後的密令：「絕不能讓公主落入敵人手中。」這把刀背後，究竟藏著什麼樣的真相？"
category = &"character"
source_loop = 0
unlocks_branches = ["branch_retainer_special"]

[sub_resource type="Resource" id="intel_retainer_motive"]
script = ExtResource("2")
id = "intel_retainer_motive"
title = "忠臣的理由"
description = "忠臣含淚刺殺公主——他說這是為了保護她免受更殘酷的命運。但這真的是全部的理由嗎？"
category = &"character"
source_loop = 1
unlocks_branches = ["branch_b"]

[sub_resource type="Resource" id="intel_faction_a"]
script = ExtResource("2")
id = "intel_faction_a"
title = "勢力 A 的線索"
description = "王國內部存在一股暗流——某些貴族似乎早已知道戰爭將至，卻選擇了沉默。"
category = &"conspiracy"
source_loop = 1
unlocks_branches = ["branch_c"]

[sub_resource type="Resource" id="intel_faction_b"]
script = ExtResource("2")
id = "intel_faction_b"
title = "勢力 B 的線索"
description = "邊境的將軍們收到了矛盾的命令——有人在刻意削弱王國的防線。"
category = &"conspiracy"
source_loop = 2
unlocks_branches = ["branch_d"]

[sub_resource type="Resource" id="intel_conspiracy_evidence"]
