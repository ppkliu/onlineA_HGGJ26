description = "城門被打開不是混亂造成的巧合，而是有人預先安排好的內應行動。"
category = &"conspiracy"
source_loop = 1
unlocks_branches = []

[sub_resource type="Resource" id="intel_chancellor_poison"]
script = ExtResource("2")
id = "intel_chancellor_poison"
title = "花茶裡的毒"
description = "宰相在最後用一杯溫熱的花茶結束了公主的生命。那份溫柔本身就是謀殺的一部分。"
category = &"conspiracy"
source_loop = 1
