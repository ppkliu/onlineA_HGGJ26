[gd_resource type="Resource" script_class="IntelDatabase" load_steps=25 format=3]

[ext_resource type="Script" path="res://resources/intel_data/intel_database.gd" id="1"]
[ext_resource type="Script" path="res://resources/intel_data/intel_item.gd" id="2"]

[sub_resource type="Resource" id="intel_city_fall"]
script = ExtResource("2")
id = "intel_city_fall"
title = "城破的結果"
description = "王城在大火中陷落，一切都在一夜之間崩塌。這是公主親眼見證的末日。"
category = &"general"
source_loop = 0
unlocks_branches = []

[sub_resource type="Resource" id="intel_assassination"]
script = ExtResource("2")
id = "intel_assassination"
title = "騎士長的刀"
description = "騎士長賽拉斯含淚刺殺了公主——他說這是國王最後的密令：「絕不能讓公主落入敵人手中。」這把刀背後，究竟藏著什麼樣的真相？"
category = &"character"
source_loop = 0
unlocks_branches = []

[sub_resource type="Resource" id="intel_magic_core_sabotage"]
script = ExtResource("2")
id = "intel_magic_core_sabotage"
title = "魔法核心的破壞"
description = "城防魔法陣的能源核心被人從內部破壞，導致城牆的魔法防護徹底失效。是誰有能力接觸核心？"
category = &"conspiracy"
source_loop = 0
unlocks_branches = []

[sub_resource type="Resource" id="intel_chancellor_betrayal"]
script = ExtResource("2")
id = "intel_chancellor_betrayal"
title = "宰相的真面目"
description = "宰相莫里昂用精心設計的半真半假，操弄公主交出城防令印。他從始至終都在利用公主的天真。"
category = &"conspiracy"
source_loop = 1
unlocks_branches = []

[sub_resource type="Resource" id="intel_fake_ledgers"]
script = ExtResource("2")
id = "intel_fake_ledgers"
title = "偽造的帳簿"
description = "宰相呈給公主的財政帳簿是偽造的——國王的稅金實際上全部用於備戰和地下防線建設。"
category = &"conspiracy"
source_loop = 1
unlocks_branches = []

[sub_resource type="Resource" id="intel_chancellor_poison"]
script = ExtResource("2")
id = "intel_chancellor_poison"
title = "花茶裡的毒"
description = "宰相在慶功的花茶中下毒，以最溫柔的方式結束了公主的生命。連殺人的方式都像在哄孩子。"
category = &"conspiracy"
source_loop = 1
unlocks_branches = []

[sub_resource type="Resource" id="intel_mob_manipulation"]
script = ExtResource("2")
id = "intel_mob_manipulation"
title = "被操弄的暴民"
description = "下城區的暴民被外部勢力利用——他們以為出賣公主能換來糧食，卻只是更大棋局中的棄子。"
category = &"conspiracy"
source_loop = 2
unlocks_branches = []

[sub_resource type="Resource" id="intel_starvation_real"]
script = ExtResource("2")
id = "intel_starvation_real"
title = "飢荒是真的"
description = "下城區的飢荒並非完全捏造。重稅、徵兵、軍需優先——百姓的苦難有一部分是備戰的真實代價。"
category = &"general"
source_loop = 2
unlocks_branches = []

[sub_resource type="Resource" id="intel_bruno_wife_death"]
script = ExtResource("2")
id = "intel_bruno_wife_death"
title = "布魯諾的悲劇"
description = "鐵匠布魯諾的妻子死於難產——所需的止血草被徵為軍需。「軍需優先」四個字，是他永遠的傷疤。"
category = &"character"
source_loop = 2
unlocks_branches = []

[sub_resource type="Resource" id="intel_king_truth"]
script = ExtResource("2")
id = "intel_king_truth"
title = "國王的真相"
description = "國王並非暴君——他用自己的名聲作擋箭牌，秘密建造不依賴魔法的地下防線，為的是在魔法陣被破壞後還能守住王城。"
category = &"truth"
source_loop = 3
unlocks_branches = []

[sub_resource type="Resource" id="intel_dal_blinded_voice"]
script = ExtResource("2")
id = "intel_dal_blinded_voice"
title = "達爾記得的聲音"
description = "被弄瞎的老工匠達爾只記得一件事：那個人說話的方式——「很輕、很慢，像在唸詩。」這個聲音的主人是誰？"
category = &"character"
source_loop = 3
unlocks_branches = []

[sub_resource type="Resource" id="intel_magic_sabotage"]
script = ExtResource("2")
id = "intel_magic_sabotage"
title = "魔法陣的腐蝕"
description = "地下防線的能源管線上有定期腐蝕的痕跡——有人一直在從內部破壞城防魔法陣。"
category = &"conspiracy"
source_loop = 3
unlocks_branches = []

[sub_resource type="Resource" id="intel_granary_lock_finance"]
script = ExtResource("2")
id = "intel_granary_lock_finance"
title = "糧倉上的印記"
description = "地下糧倉的鎖上刻著財政署的印記，製造日期比防線完工晚三個月。財政署是宰相直管的部門。"
category = &"conspiracy"
source_loop = 3
unlocks_branches = []

[sub_resource type="Resource" id="intel_chancellor_treason"]
script = ExtResource("2")
id = "intel_chancellor_treason"
title = "宰相的叛國鐵證"
description = "所有線索匯聚成一個結論：弄瞎達爾、腐蝕魔法陣、截留救濟糧、操弄暴民——全部出自宰相莫里昂之手。"
category = &"truth"
source_loop = 3
unlocks_branches = []

[sub_resource type="Resource" id="intel_king_defense_line"]
script = ExtResource("2")
id = "intel_king_defense_line"
title = "地下防線的存在"
description = "國王秘密建造的純機械防線——不靠魔法，只靠齒輪、落石、鐵閘。需要三個人同時啟動。這是他用兩年時間和整個國家的名聲換來的最後防線。"
category = &"truth"
source_loop = 3
unlocks_branches = []

[sub_resource type="Resource" id="intel_dal_blinded_by_chancellor"]
script = ExtResource("2")
id = "intel_dal_blinded_by_chancellor"
title = "弄瞎達爾的人"
description = "達爾記得的聲音——「很輕、很慢，像在唸詩」——那是宰相莫里昂獨有的語調。弄瞎達爾的不是國王，是宰相。"
category = &"truth"
source_loop = 3
unlocks_branches = []

[sub_resource type="Resource" id="intel_king_anger"]
script = ExtResource("2")
id = "intel_king_anger"
title = "國王的憤怒"
description = "國王得知有人給公主看帳簿後勃然大怒，將公主禁足。他知道有人在暗中操弄——但他不信任一個什麼都不知道的公主。"
category = &"character"
source_loop = 1
unlocks_branches = []

[sub_resource type="Resource" id="intel_chancellor_eyes"]
script = ExtResource("2")
id = "intel_chancellor_eyes"
title = "宰相的眼線"
description = "宰相在城堡裡布滿了眼線，公主的一舉一動都被監視。想從城堡內部偷帶物資——不可能。"
category = &"conspiracy"
source_loop = 2
unlocks_branches = []

[sub_resource type="Resource" id="intel_granary_needs_key"]
script = ExtResource("2")
id = "intel_granary_needs_key"
title = "打不開的糧倉"
description = "地下糧倉的鎖不是王家紋章——是財政署的印記。需要財政署印章才能打開。光有承諾打不開任何一把鎖。"
category = &"conspiracy"
source_loop = 2
unlocks_branches = []

[sub_resource type="Resource" id="intel_chancellor_dismisses_testimony"]
script = ExtResource("2")
id = "intel_chancellor_dismisses_testimony"
title = "口述不是證據"
description = "拿一個瞎子的口述去質問嫌犯，只會暴露自己的線索。宰相輕鬆化解了指控，並在當晚處理掉了達爾。"
category = &"conspiracy"
source_loop = 3
unlocks_branches = []

[sub_resource type="Resource" id="intel_king_will_listen"]
script = ExtResource("2")
id = "intel_king_will_listen"
title = "父王願意聽"
description = "國王願意聽有具體觀察的公主的話——但不能讓宰相在場。告訴父王是可行的，前提是先中立化宰相的影響力。"
category = &"truth"
source_loop = 3
unlocks_branches = []

[sub_resource type="Resource" id="intel_defense_needs_three"]
script = ExtResource("2")
id = "intel_defense_needs_three"
title = "三人才能啟動"
description = "地下防線的三道機關必須三人同時施力。這不是速度問題——是物理限制。一個人永遠不夠。"
category = &"truth"
source_loop = 3
unlocks_branches = []

[sub_resource type="Resource" id="intel_chancellor_escape_plan"]
script = ExtResource("2")
id = "intel_chancellor_escape_plan"
title = "宰相的後路"
description = "宰相早就準備好了逃跑計劃。直接去抓他只會讓他提前動手——必須在所有人面前公開定罪，才能堵死每一條退路。"
category = &"conspiracy"
source_loop = 4
unlocks_branches = []

