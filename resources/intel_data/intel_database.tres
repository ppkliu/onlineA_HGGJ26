[gd_resource type="Resource" script_class="IntelDatabase" load_steps=48 format=3]

[ext_resource type="Script" path="res://resources/intel_data/intel_database.gd" id="1"]
[ext_resource type="Script" path="res://resources/intel_data/intel_item.gd" id="2"]

[sub_resource type="Resource" id="intel_city_fall"]
script = ExtResource("2")
id = "intel_city_fall"
title = "城破的結果"
description = "王城在大火中陷落，一切都在一夜之間崩塌。這是公主親眼見證的末日。"
category = &"general"
source_loop = 0
unlocks_branches = []

[sub_resource type="Resource" id="intel_assassination"]
script = ExtResource("2")
id = "intel_assassination"
title = "騎士長的刀"
description = "賽拉斯含淚刺殺了公主。那不是單純的背叛，而是一道被迫執行的最後命令。"
category = &"character"
source_loop = 0
unlocks_branches = ["branch_a"]

[sub_resource type="Resource" id="intel_magic_core_sabotage"]
script = ExtResource("2")
id = "intel_magic_core_sabotage"
title = "失效的魔法核心"
description = "亡國之夜以前，王城的核心防禦早已被動過手腳。城破不是單一失誤，而是預謀已久的崩壞。"
category = &"truth"
source_loop = 0
unlocks_branches = []

[sub_resource type="Resource" id="intel_food_change"]
script = ExtResource("2")
id = "intel_food_change"
title = "消失的鮮食"
description = "餐桌上的鮮肉與新鮮食材不見了，取而代之的是耐放卻單調的戰備糧食。"
category = &"general"
source_loop = 1
unlocks_branches = ["branch_b"]

[sub_resource type="Resource" id="intel_maid_tears"]
script = ExtResource("2")
id = "intel_maid_tears"
title = "侍女的眼淚"
description = "莉娜強顏歡笑，眼睛卻紅得發腫。城堡的平靜表面下，有人在為家人和生計默默流淚。"
category = &"character"
source_loop = 1
unlocks_branches = ["branch_b"]

[sub_resource type="Resource" id="intel_chancellor_wealth"]
script = ExtResource("2")
id = "intel_chancellor_wealth"
title = "宰相的錢從哪來"
description = "在人人都勒緊褲帶的時候，宰相的莊園和珠寶卻越來越奢華。這筆財富顯然有問題。"
category = &"conspiracy"
source_loop = 1
unlocks_branches = []

[sub_resource type="Resource" id="intel_retainer_warning"]
script = ExtResource("2")
id = "intel_retainer_warning"
title = "騎士長的警告"
description = "賽拉斯沒有解釋真相，只留下一句警告：不要信任任何主動靠近的人。"
category = &"character"
source_loop = 1
unlocks_branches = []

[sub_resource type="Resource" id="intel_chancellor_betrayal"]
script = ExtResource("2")
id = "intel_chancellor_betrayal"
title = "宰相的背叛"
description = "莫里昂親手打開了通往滅亡的城門。這不是猜測，而是公主親眼見證的背叛。"
category = &"conspiracy"
source_loop = 1
unlocks_branches = ["final_branch"]

[sub_resource type="Resource" id="intel_fake_ledgers"]
script = ExtResource("2")
id = "intel_fake_ledgers"
title = "偽造帳簿"
description = "用來證明國王奢侈與暴虐的帳簿是偽造的。有人精心設計了一整套說得通的謊言。"
category = &"conspiracy"
source_loop = 1
unlocks_branches = []

[sub_resource type="Resource" id="intel_gate_open_signal"]
script = ExtResource("2")
